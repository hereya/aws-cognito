{
  "name": "aws-cognito",
  "version": "0.1.0",
  "bin": {
    "aws-cognito": "bin/aws-cognito.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "pretest:e2e": "STACK_NAME=e2etestAwsCognitoStack121 npx cdk deploy --require-approval never",
    "test:e2e": "STACK_NAME=e2etestAwsCognitoStack121 jest --config jest.e2e.config.js --runInBand",
    "posttest:e2e": "STACK_NAME=e2etestAwsCognitoStack121 npx cdk destroy --force",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1033.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "aws-cdk-lib": "2.215.0",
    "constructs": "^10.0.0"
  }
}
